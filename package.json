{
  "name": "recall-bench",
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "description": "RECALL: A benchmark for memory systems that rewards forgetting as much as remembering",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
