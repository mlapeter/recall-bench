    "test:watch": "vitest",
    "bench": "node --loader ts-node/esm src/cli.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  }
}
